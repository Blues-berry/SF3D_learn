{
  "supervisor_version": "sf3d_material_refine_dataset_supervisor_7day_v1",
  "notes": [
    "Data-only supervisor: keeps download, render/preprocess, merge, audit, and validation loops alive for seven days.",
    "GPU1 is intentionally kept untouched; this supervisor only maintains GPU0 data processing.",
    "No training command is launched from this supervisor.",
    "Storage policy: future heavy render/preprocess roots are supervised under /4T; active repo-output runs are not moved.",
    "2026-04-26 policy: do not resume legacy 3D-FUTURE / 3D furniture roots; future dataset expansion is driven by factory no-3DFUTURE inputs plus Objaverse/ABO/benchmark/material/HDRI sources."
  ],
  "storage_policy": {
    "large_render_output_root": "/4T/CXY/sf3d_material_refine_dataset_factory",
    "large_aux_download_root": "/4T/CXY/sf3d_material_refine_aux_downloads",
    "repo_output_role": "lightweight manifests, reports, audits, and compatibility indexes only",
    "do_not_move_active_runs": true
  },
  "duration_days": 7,
  "poll_seconds": 300,
  "session_name": "sf3d_material_refine_dataset_7day_supervisor",
  "output_root": "output/material_refine_dataset_factory/supervisor_7day",
  "python_bin": "/home/ubuntu/ssd_work/conda_envs/sf3d/bin/python",
  "factory": {
    "enabled": true,
    "session": "sf3d_material_refine_dataset_factory_gpu0",
    "config": "configs/material_refine_dataset_factory_gpu0.json",
    "state_json": "output/material_refine_dataset_factory/factory_state.json",
    "log": "output/material_refine_dataset_factory/factory_gpu0_loop.log",
    "run_script": "output/material_refine_dataset_factory/factory_gpu0_loop.run.sh",
    "loop_flags": [
      "--loop",
      "--start-downloads",
      "--start-render",
      "--audit"
    ]
  },
  "gpu_policy": {
    "render_gpu": 0,
    "keep_gpu_indices_empty": [1],
    "allow_gpu1_data_processes": false,
    "max_gpu1_data_memory_mb": 0,
    "warn_if_data_process_on_gpu1": true
  },
  "downloads": {
    "required_sessions": [
      "sf3d_factory_polyhaven_material_bank"
    ]
  },
  "production_roots": {
    "patterns": [],
    "latest_only": true,
    "required_prefixes": [
      "sf3d_longrun_material_refine_shard",
      "sf3d_longrun_material_refine_merged_monitor"
    ],
    "merge_output_name": "canonical_manifest_supervisor_merged.json",
    "groups": [
      {
        "name": "scarce_material_topup",
        "enabled": false,
        "patterns": [
          "/4T/CXY/sf3d_material_refine_dataset_factory/scarce_material_gpu0_2*",
          "output/material_refine_dataset_factory/scarce_material_gpu0_2*"
        ],
        "latest_only": true,
        "required_prefixes": [
          "sf3d_scarce_material_refine_shard",
          "sf3d_scarce_material_refine_merged_monitor"
        ],
        "merge_output_name": "canonical_manifest_supervisor_merged.json"
      },
      {
        "name": "scarce_fast_unlock_topup",
        "enabled": false,
        "patterns": [
          "/4T/CXY/sf3d_material_refine_dataset_factory/scarce_material_gpu0_fast_unlock_*",
          "output/material_refine_dataset_factory/scarce_material_gpu0_fast_unlock_*"
        ],
        "latest_only": true,
        "required_prefixes": [
          "sf3d_scarce_fast_unlock_material_refine_shard",
          "sf3d_scarce_fast_unlock_material_refine_merged_monitor"
        ],
        "merge_output_name": "canonical_manifest_supervisor_merged.json"
      },
      {
        "name": "scarce_gpu1_limited_topup",
        "enabled": false,
        "patterns": [
          "/4T/CXY/sf3d_material_refine_dataset_factory/scarce_material_gpu1_limited_*"
        ],
        "latest_only": true,
        "required_prefixes": [
          "sf3d_scarce_gpu1_limited_material_refine_merged_monitor"
        ],
        "merge_output_name": "canonical_manifest_supervisor_merged.json"
      },
      {
        "name": "scarce_gpu1_full_topup",
        "enabled": false,
        "patterns": [
          "/4T/CXY/sf3d_material_refine_dataset_factory/scarce_material_gpu1_full_*"
        ],
        "latest_only": true,
        "required_prefixes": [
          "sf3d_scarce_gpu1_full_material_refine_merged_monitor"
        ],
        "merge_output_name": "canonical_manifest_supervisor_merged.json"
      },
      {
        "name": "scarce_gpu1_extra_topup",
        "enabled": false,
        "patterns": [
          "/4T/CXY/sf3d_material_refine_dataset_factory/scarce_material_gpu1_extra_*"
        ],
        "latest_only": true,
        "required_prefixes": [
          "sf3d_scarce_gpu1_extra_material_refine_shard",
          "sf3d_scarce_gpu1_extra_material_refine_merged_monitor"
        ],
        "merge_output_name": "canonical_manifest_supervisor_merged.json"
      },
      {
        "name": "scarce_gpu1_safe_topup",
        "enabled": false,
        "patterns": [
          "/4T/CXY/sf3d_material_refine_dataset_factory/scarce_material_gpu1_safe_*"
        ],
        "latest_only": true,
        "required_prefixes": [
          "sf3d_scarce_gpu1_safe_material_refine_merged_monitor"
        ],
        "merge_output_name": "canonical_manifest_supervisor_merged.json"
      },
      {
        "name": "scarce_gpu1_ceramic_topup",
        "enabled": false,
        "patterns": [
          "/4T/CXY/sf3d_material_refine_dataset_factory/scarce_material_gpu1_ceramic_[0-9]*"
        ],
        "latest_only": true,
        "required_prefixes": [
          "sf3d_scarce_gpu1_ceramic_material_refine_merged_monitor"
        ],
        "merge_output_name": "canonical_manifest_supervisor_merged.json"
      },
      {
        "name": "scarce_gpu1_ceramic_retry_topup",
        "enabled": false,
        "patterns": [
          "/4T/CXY/sf3d_material_refine_dataset_factory/scarce_material_gpu1_ceramic_retry_*"
        ],
        "latest_only": true,
        "required_prefixes": [
          "sf3d_scarce_gpu1_ceramic_retry_material_refine_merged_monitor"
        ],
        "merge_output_name": "canonical_manifest_supervisor_merged.json"
      },
      {
        "name": "scarce_gpu1_glossy_topup",
        "enabled": false,
        "patterns": [
          "/4T/CXY/sf3d_material_refine_dataset_factory/scarce_material_gpu1_glossy_*"
        ],
        "latest_only": true,
        "required_prefixes": [
          "sf3d_scarce_gpu1_glossy_material_refine_merged_monitor"
        ],
        "merge_output_name": "canonical_manifest_supervisor_merged.json"
      },
      {
        "name": "objaverse_cached_topup",
        "enabled": false,
        "patterns": [
          "output/material_refine_dataset_factory/objaverse_cached_gpu0_*"
        ],
        "latest_only": true,
        "required_prefixes": [
          "sf3d_objaverse_cached_refine_shard",
          "sf3d_objaverse_cached_refine_merged_monitor"
        ],
        "merge_output_name": "canonical_manifest_supervisor_merged.json"
      }
    ]
  },
  "paper_unlock": {
    "enabled": false,
    "root_pattern": "output/material_refine_dataset_factory/paper_unlock_gpu0_*",
    "latest_only": true,
    "target_eligible_records": 128,
    "target_total_records": 256,
    "required_prefixes": [
      "sf3d_paper_unlock_material_refine_shard",
      "sf3d_paper_unlock_material_refine_merged_monitor"
    ],
    "merge_output_name": "canonical_manifest_supervisor_merged.json",
    "launch_env": {
      "SESSION_PREFIX": "sf3d_paper_unlock_material_refine",
      "MAX_RECORDS": "256",
      "SHARDS": "4",
      "GPU_LIST": "0",
      "WORKERS_PER_GPU": "1",
      "VIEW_LIGHT_PROTOCOL": "standard_12",
      "MAX_HDRI_LIGHTS": "2",
      "MIN_HDRI_COUNT": "900",
      "ATLAS_RESOLUTION": "768",
      "RENDER_RESOLUTION": "256",
      "CYCLES_SAMPLES": "8",
      "REFRESH_PARTIAL_EVERY": "1",
      "MERGED_MONITOR_POLL_SECONDS": "30",
      "LONGRUN_INPUT_MANIFESTS": "output/highlight_pool_a_8k/material_refine_manifest_pool_a_no_3dfuture.json",
      "PAPER_MAIN_SOURCES": "ABO_locked_core",
      "AUXILIARY_SOURCES": "",
      "PRIORITY_MATERIAL_FAMILIES": "metal_dominant,glass_metal,mixed_thin_boundary,ceramic_glazed_lacquer,glossy_non_metal",
      "PAPER_FRONTLOAD_RECORDS": "256",
      "PREFER_PAPER_MAIN_FIRST": "1",
      "START_MERGED_MONITOR": "1"
    }
  },
  "quality": {
    "enabled": true,
    "audit_every_seconds": 900,
    "buffer_validation_every_seconds": 1800,
    "min_manifest_records_for_audit": 8,
    "min_paper_eligible": 128,
    "min_view_ready_rate": 0.8,
    "min_strict_complete_rate": 0.8
  },
  "log_scan": {
    "enabled": true,
    "tail_bytes_per_log": 2097152,
    "scan_from_end_on_first_seen": true,
    "ignore_names": [
      "sf3d_material_refine_dataset_7day_supervisor.log"
    ],
    "patterns": [
      "unhashable type",
      "Out of memory",
      "CUDA error",
      "RuntimeError: Error",
      "Traceback"
    ],
    "max_lines": 120
  }
}
