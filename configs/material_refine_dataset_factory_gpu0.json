      "license_policy": "mixed individual licenses; filtered before render",
      "promotion_gate": "license + import + material-probe + target gate"
    },
    {
      "name": "Objaverse-XL_strict_filtered_retry",
      "pool": "Pool-A auxiliary upgrade queue",
      "role": "network-fed Objaverse increment",
      "manifest_glob": "output/material_refine_aux_downloads/objaverse_strict*/objaverse_xl_strict_filtered_manifest.json",
      "license_policy": "noncommercial/ND/unknown blocked",
      "promotion_gate": "downloaded local asset + import + target gate"
    },
    {
      "name": "PolyHaven_HDRI",
      "pool": "Pool-D",
      "role": "natural/stress lighting bank",
      "manifest": "output/highlight_pool_a_8k/aux_sources/polyhaven_hdri_bank.json",
      "license_policy": "CC0",
      "promotion_gate": "lighting only; not object supervision"
    },
    {
      "name": "PolyHaven_Materials",
      "pool": "Pool-E",
      "role": "PBR material prior bank",
