      "license_policy": "benchmark sidecar; keep out of Pool-A main train",
      "promotion_gate": "benchmark/calibration only"
    },
    {
      "name": "Stanford-ORB",
      "pool": "Pool-F",
      "role": "real OOD benchmark",
      "manifest": "output/material_refine_real_benchmarks/stanford_orb_pool_f/stanford_orb_benchmark_manifest.json",
      "license_policy": "benchmark sidecar; keep out of train",
      "promotion_gate": "final OOD evaluation only"
    }
  ],
