{
  "factory_version": "sf3d_material_refine_dataset_factory_v1",
  "notes": [
    "Continuous dataset expansion plan for SF3D material-refine data only; no training is launched here.",
    "GPU policy allows data-only render/preprocess work to fully use GPU1 when needed; no training is launched here.",
    "Pool-A paper promotion remains gated by license/import/target-quality audits; auxiliary and benchmark pools are explicitly marked.",
    "Storage policy: future heavy render/preprocess outputs go to /4T; repo output keeps lightweight reports/manifests."
  ],
  "storage_policy": {
    "large_render_output_root": "/4T/CXY/sf3d_material_refine_dataset_factory",
    "large_aux_download_root": "/4T/CXY/sf3d_material_refine_aux_downloads",
    "repo_output_role": "lightweight manifests, reports, audits, and compatibility indexes only",
    "do_not_move_active_runs": true
  },
  "gpu_policy": {
    "render_gpu_list": "0",
    "keep_gpu_indices_empty": [],
    "allow_gpu1_data_processes": true,
    "max_gpu1_data_memory_mb": 32607,
    "max_gpu0_used_mb_for_new_launch": 4096,
    "poll_seconds": 300
  },
  "download_network": {
    "proxy_candidates": [
      "env",
      "http://127.0.0.1:51081",
      "http://127.0.0.1:7890",
      "http://127.0.0.1:7891",
      "http://127.0.0.1:10809",
      "direct"
    ],
    "proxy_probe_timeout_seconds": 8,
    "hf_endpoint_candidates": ["env", "https://huggingface.co", "https://hf-mirror.com"],
    "hf_endpoint_probe_timeout_seconds": 8,
    "default_probe_url": "https://huggingface.co/"
  },
  "targets": {
    "production_total_objects": 12000,
    "active_longrun_records": 9700,
    "objaverse_strict_increment_target": 6000,
    "polyhaven_hdri_min_count": 900,
    "polyhaven_hdri_target_count": 1200,
    "material_prior_target_count": 1000
  },
  "source_roles": [
    {
      "name": "ABO_locked_core",
      "pool": "Pool-A",
      "role": "paper_main_seed",
